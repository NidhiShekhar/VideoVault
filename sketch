#### Input Validation
```go
type VideoMetadataRequest struct {
    Title      string `form:"title" validate:"required,min=3,max=255"`
    Description string `form:"description" validate:"max=2000"`
    UploaderID string `form:"uploaderId" validate:"required,uuid4"`
}

type VideoValidator struct {
    validate            *validator.Validate
    maxFileSize         int64
    allowedContentTypes map[string]struct{}
}

func NewVideoValidator() *VideoValidator {
    return &VideoValidator{
        validate:    validator.New(),
        maxFileSize: 2 * 1024 * 1024 * 1024,
        allowedContentTypes: map[string]struct{}{
            "video/mp4":        {},
            "video/mpeg":       {},
            "video/quicktime":  {},
            "video/x-msvideo":  {},
            "video/x-matroska": {},
        },
    }
}

func (v *VideoValidator) Validate(file *multipart.FileHeader, metadata VideoMetadataRequest) error {
    if err := v.validate.Struct(metadata); err != nil {
        return fmt.Errorf("invalid metadata: %w", err)
    }
    if file == nil || file.Size == 0 {
        return ErrInvalidFile
    }
    if file.Size > v.maxFileSize {
        return fmt.Errorf("file size exceeds maximum limit of 2GB")
    }
    return nil
}
