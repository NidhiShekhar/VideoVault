@Service
@Slf4j
@RequiredArgsConstructor
public class VideoUploadConsumer {
    
    private final EncodingService encodingService;
    
    @KafkaListener(topics = \"uploaded-videos\", groupId = \"encoder-service-group\")
    public void consume(
            @Payload VideoUploadEvent event,
            @Header(KafkaHeaders.RECEIVED_PARTITION_ID) int partition,
            Acknowledgment acknowledgment) {
        
        log.info(\"Received video upload event: videoId={}, partition={}\", 
                event.getVideoId(), partition);
        
        try {
            // Process the video
            encodingService.encodeVideo(event);
            
            // Manually commit offset only after successful processing
            acknowledgment.acknowledge();
            log.info(\"Successfully processed video: {}\", event.getVideoId());
            
        } catch (Exception e) {
            log.error(\"Failed to process video: {}\", event.getVideoId(), e);
            // Don't acknowledge - message will be redelivered
            // Consider implementing Dead Letter Queue (DLQ) after max retries
        }
    }
}
