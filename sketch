### 7. Error Handling & Resilience

#### Global Error Handler
```go
type ErrorResponse struct {
    Status    int       `json:"status"`
    Error     string    `json:"error"`
    Message   string    `json:"message"`
    Timestamp time.Time `json:"timestamp"`
}

func ErrorMiddleware(logger *zap.Logger) gin.HandlerFunc {
    return func(c *gin.Context) {
        c.Next()

        if len(c.Errors) == 0 {
            return
        }

        err := c.Errors.Last().Err
        status := http.StatusInternalServerError
        errName := "Internal Server Error"
        msg := "An unexpected error occurred"

        switch {
        case errors.Is(err, ErrInvalidFile):
            status = http.StatusBadRequest
            errName = "Invalid File"
            msg = err.Error()
        case errors.Is(err, ErrVideoNotFound):
            status = http.StatusNotFound
            errName = "Video Not Found"
            msg = err.Error()
        case errors.Is(err, ErrEncodingFailed):
            status = http.StatusInternalServerError
            errName = "Encoding Failed"
            msg = "Video encoding failed. Please try again."
        }

        logger.Error("request failed", zap.Int("status", status), zap.Error(err))
        c.JSON(status, ErrorResponse{Status: status, Error: errName, Message: msg, Timestamp: time.Now().UTC()})
    }
}
```

#### Retry + Circuit Breaker Logic
```go
retryPolicy := retry.NewExponential(3, 1*time.Second)
cb := gobreaker.NewCircuitBreaker(gobreaker.Settings{
    Name:        "s3Upload",
    MaxRequests: 3,
    Interval:    10 * time.Second,
    Timeout:     10 * time.Second,
    ReadyToTrip: func(counts gobreaker.Counts) bool {
        if counts.Requests < 5 {
            return false
        }
        failureRate := float64(counts.TotalFailures) / float64(counts.Requests)
        return failureRate >= 0.5
    },
})

func (s *S3Service) UploadFile(ctx context.Context, bucketName, key string, filePath string) (string, error) {
    var url string
    err := retryPolicy.Do(ctx, func() error {
        _, err := cb.Execute(func() (any, error) {
            uploadedURL, uploadErr := s.uploadOnce(ctx, bucketName, key, filePath)
            if uploadErr != nil {
                return nil, uploadErr
            }
            url = uploadedURL
            return nil, nil
        })
        return err
    })
    return url, err
}
```

