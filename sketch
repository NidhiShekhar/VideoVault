#### Retry Logic with Resilience4j
```java
@Service
@Slf4j
@RequiredArgsConstructor
public class S3ServiceWithRetry {
    
    private final AmazonS3 s3Client;
    
    @Retry(name = \"s3Upload\", fallbackMethod = \"uploadFallback\")
    @CircuitBreaker(name = \"s3Upload\")
    public String uploadFile(String bucketName, String key, File file) {
        log.info(\"Attempting to upload file to S3: {}/{}\", bucketName, key);
        
        PutObjectRequest request = new PutObjectRequest(bucketName, key, file);
        s3Client.putObject(request);
        
        return s3Client.getUrl(bucketName, key).toString();
    }
    
    private String uploadFallback(String bucketName, String key, File file, Exception e) {
        log.error(\"Failed to upload to S3 after retries: {}/{}\", bucketName, key, e);
        throw new S3UploadException(\"Failed to upload file to S3\", e);
    }
}
