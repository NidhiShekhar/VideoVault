### 9. Security Best Practices

#### Basic Security Configuration
```go
func AuthAndCorsMiddleware(cfg Config) gin.HandlerFunc {
    allowedOrigins := map[string]struct{}{"http://localhost:3000": {}}

    return func(c *gin.Context) {
        origin := c.GetHeader("Origin")
        if _, ok := allowedOrigins[origin]; ok {
            c.Writer.Header().Set("Access-Control-Allow-Origin", origin)
            c.Writer.Header().Set("Access-Control-Allow-Credentials", "true")
            c.Writer.Header().Set("Access-Control-Allow-Headers", "Authorization, Content-Type, X-Correlation-ID")
            c.Writer.Header().Set("Access-Control-Allow-Methods", "GET, POST, PUT, DELETE, OPTIONS")
        }

        if c.Request.Method == http.MethodOptions {
            c.Status(http.StatusNoContent)
            return
        }

        if strings.HasPrefix(c.Request.URL.Path, "/api/v1/videos/upload") {
            if err := validateJWT(c.GetHeader("Authorization"), cfg.Auth.JWTSecret); err != nil {
                c.AbortWithStatusJSON(http.StatusUnauthorized, gin.H{"error": "unauthorized"})
                return
            }
        }

        c.Next()
    }
}
