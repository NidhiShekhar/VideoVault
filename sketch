```java
@GrpcService
@Slf4j
@RequiredArgsConstructor
public class MetadataServiceImpl extends MetadataServiceGrpc.MetadataServiceImplBase {
    
    private final MetadataService metadataService;
    private final VideoMetadataMapper mapper;
    
    @Override
    public void storeMetadata(VideoMetadataProto.VideoMetadata request,
                            StreamObserver<VideoMetadataProto.MetadataResponse> responseObserver) {
        try {
            log.info(\"Received store metadata request for video: {}\", request.getVideoId());
            
            Video video = mapper.toEntity(request);
            metadataService.saveMetadata(video);
            
            VideoMetadataProto.MetadataResponse response = VideoMetadataProto.MetadataResponse
                    .newBuilder()
                    .setSuccess(true)
                    .setMessage(\"Metadata stored successfully\")
                    .build();
            
            responseObserver.onNext(response);
            responseObserver.onCompleted();
            
        } catch (Exception e) {
            log.error(\"Error storing metadata\", e);
            responseObserver.onError(Status.INTERNAL
                    .withDescription(\"Failed to store metadata: \" + e.getMessage())
                    .asRuntimeException());
        }
    }
    
    @Override
    public void getVideoById(VideoMetadataProto.VideoIdRequest request,
                           StreamObserver<VideoMetadataProto.VideoMetadata> responseObserver) {
        try {
            String videoId = request.getVideoId();
            log.info(\"Received get video request: {}\", videoId);
            
            Video video = metadataService.getVideoById(videoId)
                    .orElseThrow(() -> new VideoNotFoundException(\"Video not found: \" + videoId));
            
            VideoMetadataProto.VideoMetadata response = mapper.toProto(video);
            
            responseObserver.onNext(response);
            responseObserver.onCompleted();
            
        } catch (VideoNotFoundException e) {
            log.error(\"Video not found\", e);
            responseObserver.onError(Status.NOT_FOUND
                    .withDescription(e.getMessage())
                    .asRuntimeException());
        } catch (Exception e) {
            log.error(\"Error retrieving video\", e);
            responseObserver.onError(Status.INTERNAL
                    .withDescription(\"Failed to retrieve video\")
                    .asRuntimeException());
        }
    }
}
