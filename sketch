```java
@Service
@Slf4j
public class FFmpegService {
    
    public void encodeVideo(String inputPath, String outputPath, EncodingProfile profile) {
        List<String> command = buildFFmpegCommand(inputPath, outputPath, profile);
        
        try {
            ProcessBuilder processBuilder = new ProcessBuilder(command);
            processBuilder.redirectErrorStream(true);
            
            Process process = processBuilder.start();
            
            // Monitor progress
            try (BufferedReader reader = new BufferedReader(
                    new InputStreamReader(process.getInputStream()))) {
                String line;
                while ((line = reader.readLine()) != null) {
                    log.debug(\"FFmpeg output: {}\", line);
                    // Parse progress from FFmpeg output if needed
                }
            }
            
            int exitCode = process.waitFor();
            
            if (exitCode != 0) {
                throw new EncodingException(\"FFmpeg encoding failed with exit code: \" + exitCode);
            }
            
            log.info(\"Video encoded successfully: {}\", outputPath);
            
        } catch (IOException | InterruptedException e) {
            log.error(\"Error during video encoding\", e);
            throw new EncodingException(\"Video encoding failed\", e);
        }
    }
    
    private List<String> buildFFmpegCommand(String input, String output, EncodingProfile profile) {
        List<String> command = new ArrayList<>();
        command.add(\"ffmpeg\");
        command.add(\"-i\");
        command.add(input);
        
        // Video codec settings
        command.add(\"-c:v\");
        command.add(\"libx264\");
        command.add(\"-preset\");
        command.add(\"medium\"); // balance between speed and quality
        command.add(\"-crf\");
        command.add(String.valueOf(profile.getCrf()));
        
        // Resolution and bitrate
        command.add(\"-vf\");
        command.add(String.format(\"scale=%d:%d\", profile.getWidth(), profile.getHeight()));
        command.add(\"-b:v\");
        command.add(profile.getVideoBitrate());
        command.add(\"-maxrate\");
        command.add(profile.getMaxBitrate());
        command.add(\"-bufsize\");
        command.add(profile.getBufferSize());
        
        // Audio codec settings
        command.add(\"-c:a\");
        command.add(\"aac\");
        command.add(\"-b:a\");
        command.add(profile.getAudioBitrate());
        command.add(\"-ar\");
        command.add(\"48000\"); // Sample rate
        
        // Format settings
        command.add(\"-movflags\");
        command.add(\"+faststart\"); // Enable progressive download
        command.add(\"-f\");
        command.add(\"mp4\");
        
        command.add(output);
        
        return command;
    }
}
