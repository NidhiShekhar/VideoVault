#### Consumer Implementation with Error Handling
```go
type UploadConsumer struct {
    encodingService *EncodingService
    logger          *zap.Logger
}

func (c *UploadConsumer) ConsumeClaim(session sarama.ConsumerGroupSession, claim sarama.ConsumerGroupClaim) error {
    for msg := range claim.Messages() {
        var event VideoUploadEvent
        if err := json.Unmarshal(msg.Value, &event); err != nil {
            c.logger.Error("invalid event payload", zap.Error(err))
            continue
        }

        if err := c.encodingService.EncodeVideo(session.Context(), event); err != nil {
            c.logger.Error("failed to process video", zap.String("video_id", event.VideoID), zap.Error(err))
            continue
        }

        session.MarkMessage(msg, "processed")
    }
    return nil
}
